# AI Creator Vault - Environment Configuration
# Copy this file to .env and fill in the values

# ==================== Database ====================
# Database type: sqlite or postgres
DB_TYPE=postgres

# PostgreSQL connection
DB_HOST=localhost
DB_PORT=5432
DB_NAME=aicreatorvault
DB_USER=aicreator
DB_PASSWORD=your_secure_password_here

# SQLite (if DB_TYPE=sqlite)
# DB_STORAGE=./database.db

# ==================== Storage ====================
# Upload directory path (bind mount to host)
# For NAS: use absolute path like /volume1/docker/aicreatorvault/uploads
# For local dev: use relative path ./uploads
UPLOADS_PATH=./uploads

# ==================== OpenAI ====================
# Required: Your OpenAI API key
OPENAI_API_KEY=sk-your-api-key-here

# Optional: Model configuration
OPENAI_VISION_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ==================== Xray Proxy ====================
# Path to xray config file (for OpenAI API proxy)
XRAY_CONFIG_PATH=./xray/config.json

# ==================== Optional Services ====================
# If using external services, uncomment and configure:

# External PostgreSQL (if not using docker-compose postgres)
# DB_HOST=your-postgres-host
# DB_PORT=5432

# External Redis (if not using docker-compose redis)
# REDIS_URL=redis://your-redis-host:6379

# External Qdrant (if not using docker-compose qdrant)
# QDRANT_URL=http://your-qdrant-host:6333

# ==================== Brave Search ====================
# Required: Brave Search API key for reference image search
BRAVE_API_KEY=your_brave_api_key_here

# 参考图搜索配置
REFERENCE_SEARCH_ENABLED=true
REFERENCE_SEARCH_MAX_RESULTS=50
REFERENCE_DOWNLOAD_TIMEOUT=15000

# ==================== MiniMax Image Generation ====================
# Required: MiniMax API key for AI image generation
# Get your API key from: https://platform.minimaxi.com
IMAGE_GEN_API_URL=https://api.minimaxi.com/v1/image_generation
IMAGE_GEN_API_KEY=your_minimax_api_key_here
