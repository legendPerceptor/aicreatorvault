{
  "name": "aigc-assistant",
  "version": "1.0.0",
  "description": "AI Creator Vault - Manage Your AI Assets",
  "main": "index.js",
  "scripts": {
    "start:backend": "node backend/server.js",
    "start:frontend": "cd frontend && npm run dev",
    "start:image-service": "cd image-service && uv run uvicorn main:app --host 0.0.0.0 --port 8001 --reload",
    "dev": "concurrently \"npm run start:backend\" \"npm run start:frontend\"",
    "dev:full": "concurrently \"npm run start:backend\" \"npm run start:frontend\" \"npm run start:image-service\"",
    "prepare": "pre-commit install",
    "pre-commit:run": "pre-commit run --all-files",
    "pre-commit:install": "pre-commit install --install-hooks"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "axios": "^1.6.0",
    "bcryptjs": "^2.4.3",
    "cheerio": "^1.2.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-rate-limit": "^8.3.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "pdf-parse": "^2.4.5",
    "pg": "^8.11.3",
    "pg-hstore": "^2.3.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "sequelize": "^6.37.1",
    "socks-proxy-agent": "^9.0.0",
    "sqlite3": "^5.1.7",
